# Microsoft SQL Server connection
# Ganti dengan nama server/instance SQL Server kamu
# Contoh: LAPTOP-ABC\SQLEXPRESS  atau  localhost\SQLEXPRESS  atau  localhost,1433
DB_SERVER=LAPTOP-V0TM149D

# Nama database (harus sudah dibuat via database_schema.sql)
DB_NAME=NotMyStyle

# Credentials SQL Server Authentication
DB_USER=NOTMYSTYLE
DB_PASSWORD=Database16

# JWT secret - ganti dengan string random yang kuat di production
JWT_SECRET=notmystyle_secret_key_2026

# Port server backend
DB_PORT=1433

# Asal request dari frontend (untuk CORS)
CLIENT_ORIGIN=http://localhost:5173
